---
---

<footer id="contact">
  <div class="inner">
    <div class="left">
      <h2>Let's connect.</h2>
      <p>Find me on LinkedIn — I talk about engineering,<br />corporate culture, technology, and the energy industry.</p>
    </div>
    <a
      href="https://www.linkedin.com/in/lisachan81"
      target="_blank"
      rel="noopener noreferrer"
      class="linkedin-btn"
    >
      LinkedIn →
    </a>
  </div>
  <div class="copy">
    © {new Date().getFullYear()} Lisa Chan
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--ink-faint);
    margin-top: 0;
  }

  .inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 6rem) var(--site-padding);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  h2 {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 0.5rem;
  }

  p {
    font-size: 0.9375rem;
    color: var(--ink-muted);
  }

  .linkedin-btn {
    display: inline-flex;
    align-items: center;
    background: var(--terracotta);
    color: white;
    text-decoration: none;
    padding: 0.875rem 2rem;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    white-space: nowrap;
    transition: opacity 0.2s;
    flex-shrink: 0;
  }

  .linkedin-btn:hover { opacity: 0.9; }

  .copy {
    text-align: center;
    padding: 1.5rem var(--site-padding);
    font-size: 0.75rem;
    color: var(--ink-muted);
    letter-spacing: 0.05em;
    border-top: 1px solid var(--ink-faint);
  }
</style>
