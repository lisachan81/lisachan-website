---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('writing');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const hasToc = post.data.toc === true;
const tocHeadings = headings.filter(h => h.depth === 2);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<BaseLayout title={`${post.data.title} — Lisa Chan`} description={post.data.excerpt}>
  <Nav currentPath="/writing" tocItems={tocHeadings} />
  <main>
    <article>
      <header>
        <a href="/#writing" class="back">← Writing</a>
        <p class="date">{formatDate(post.data.date)}</p>
        <h1>{post.data.title}</h1>
        <p class="excerpt">{post.data.excerpt}</p>
      </header>

      <div class:list={['article-layout', { 'has-toc': hasToc }]}>
        {hasToc && tocHeadings.length > 0 && (
          <aside class="toc-sidebar">
            <ul class="toc-list">
              {tocHeadings.map(h => (
                <li>
                  <a href={`#${h.slug}`} class="toc-link" data-slug={h.slug}>
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </aside>
        )}

        <div class="post-body">
          <Content />

          {post.data.furtherReading && post.data.furtherReading.length > 0 && (
            <div class="bibliography">
              <p class="bibliography-label">Further Reading</p>
              <div class="bib-cards">
                {post.data.furtherReading.map(item => (
                  <div class="bib-card">
                    <p class="bib-title">{item.title}</p>
                    <p class="bib-author">— {item.author}</p>
                    <p class="bib-year">{item.year}</p>
                    <p class="bib-note">{item.note}</p>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

{tocHeadings.length > 0 && (
  <script>
    const headings = [...document.querySelectorAll('.post-body h2')];
    const tocLinks = document.querySelectorAll('[data-slug]');

    function updateActive() {
      const navHeight = parseFloat(
        getComputedStyle(document.documentElement).getPropertyValue('--nav-height')
      ) || 68;
      const scrollY = window.scrollY + navHeight + 24;

      let activeSlug = headings[0]?.id ?? '';
      for (const h of headings) {
        if ((h as HTMLElement).offsetTop <= scrollY) {
          activeSlug = h.id;
        }
      }

      tocLinks.forEach(link => {
        link.classList.toggle('active', (link as HTMLElement).dataset.slug === activeSlug);
      });
    }

    window.addEventListener('scroll', updateActive, { passive: true });
    updateActive();
  </script>
)}

<style>
  main {
    padding-top: var(--nav-height);
  }

  article {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: clamp(3rem, 8vw, 6rem) var(--site-padding);
  }

  .back {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--ink-muted);
    text-decoration: none;
    letter-spacing: 0.04em;
    margin-bottom: 2.5rem;
    transition: color 0.2s;
  }

  .back:hover { color: var(--terracotta); }

  .date {
    font-size: 0.75rem;
    color: var(--ink-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  h1 {
    font-family: var(--serif);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--ink);
    margin-bottom: 1rem;
  }

  .excerpt {
    font-family: var(--serif);
    font-size: 1.125rem;
    font-style: italic;
    color: var(--ink-muted);
    margin-bottom: 3rem;
    line-height: 1.5;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--ink-faint);
  }

  /* ── ARTICLE LAYOUT ─────────────────────────────────────── */
  .article-layout {
    display: block;
  }

  .article-layout.has-toc {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 5rem;
    align-items: start;
  }

  /* ── TOC SIDEBAR ────────────────────────────────────────── */
  .toc-sidebar {
    position: sticky;
    top: calc(var(--nav-height) + 2rem);
  }

  .toc-list {
    list-style: none;
    border-left: 1px solid var(--ink-faint);
  }

  .toc-list li { margin: 0; }

  .toc-link {
    display: block;
    padding: 0.375rem 0 0.375rem 1rem;
    font-size: 0.8125rem;
    line-height: 1.4;
    color: var(--ink-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
    margin-left: -1px;
    transition: color 0.2s, border-color 0.2s;
  }

  .toc-link:hover { color: var(--ink); }

  :global(.toc-link.active) {
    color: var(--terracotta);
    border-left-color: var(--terracotta);
    font-weight: 500;
  }

  /* ── BIBLIOGRAPHY ───────────────────────────────────────── */
  .bibliography {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--ink-faint);
  }

  .bibliography-label {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
    font-weight: 500;
    margin-bottom: 0.875rem;
  }

  .bib-cards {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .bib-card {
    background: var(--cream-dark);
    border: 1px solid var(--ink-faint);
    border-radius: 4px;
    padding: 0.625rem 1rem;
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0 0.5rem;
  }

  .bib-title {
    font-family: var(--serif);
    font-size: 0.875rem;
    font-weight: 600;
  }

  .bib-author {
    font-size: 0.8125rem;
    color: var(--ink-muted);
  }

  .bib-year {
    font-size: 0.75rem;
    color: var(--ink-muted);
    letter-spacing: 0.04em;
    margin-left: auto;
  }

  .bib-note {
    font-size: 0.8125rem;
    color: var(--ink-muted);
    line-height: 1.55;
    font-style: italic;
    width: 100%;
    margin-top: 0.3rem;
  }

  /* ── RESPONSIVE ─────────────────────────────────────────── */
  @media (max-width: 800px) {
    .article-layout.has-toc {
      display: block;
    }

    .toc-sidebar {
      display: none;
    }
  }
</style>
